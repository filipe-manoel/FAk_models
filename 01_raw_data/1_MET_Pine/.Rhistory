library(survival)
# This is right-sensored data
# 0, 0, 1, *, 20, *, 10, *, *, 34
# * is above DL
# Tobit regression
# Let’s say DL = 50
values <- c(0, 0, 1, 50, 20, 50, 10, 50, 50, 34)
censored <- c(0, 0, 0, 1, 0, 1, 0, 1, 1, 0)  # 1 = censored
# Fit a censored regression model (Tobit)
model <- survreg(Surv(values, !censored, type = "right") ~ 1, dist = "gaussian")
summary(model)
# Example Kaplan-Meier
# Create a survival object for right-censored data
# type = "right" because values >50 are censored
surv_obj <- Surv(time = values, event = !censored, type = "right")
# Fit Kaplan-Meier survival curve (no groups, just 1 sample)
km_fit <- survfit(surv_obj ~ 1)
summary(km_fit)
# Plot the KM curve
plot(km_fit,
xlab = "Chemical concentration",
ylab = "Probability of Negative Result",
main = "Kaplan-Meier estimate for concentration data",
mark.time = TRUE)
