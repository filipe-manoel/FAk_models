G11inv  <- G.inverse(G = G11, sparseform = TRUE)$Ginv.sparse
G22inv  <- G.inverse(G = G22, sparseform = TRUE)$Ginv.sparse
head(G11inv)
head(G11inv)
# Fit model with FULL matrix, but partial DATA
