na.action = na.method(list(y = "omit")),
workspace = 128e06,
data = phenoy)
summary(modelGBLUP)$varcomp
# BUT we can use predict to get ONLY the BLUP term (INDIV)
#BLUP <- predict(modelGBLUP, "INDIV", only = "vm(INDIV, Ginv)", levels = observed, vcov = TRUE)
