# Chunk 27: tab_sfa1
# Extract diag(Sigma) = variances
diagSigma = vc2 %>%
bind_rows() %>%
filter(model == "mod_sfa1") %>%
filter(grepl("var", effect)) %>%
select(effect, estimate)
# Extract loadings (F)
F = vc2 %>%
bind_rows() %>%
filter(model == "mod_sfa1") %>%
filter(grepl("sfa[0-9]+", effect)) %>%
pull(estimate)
# 1) Build D = sqrt(diag(vars))
D = diag(sqrt(diagSigma$estimate))
# 2) Compute E = diag(1 - F^2)
E = diag(1 - F^2)
# 3) Compute C = F F' + E   (correlation-scale matrix)
C = F %*% t(F) + E
# 4) Reconstruct Sigma = D C D
Sigma = D %*% C %*% D
cov_sfa1 = Sigma
#CORR =cov2cor(cov_sfa1)
cov_sfa1
# Chunk 28
round(diag(cov_us)-diag(cov_sfa1),3)
# Chunk 29
# Função para extrair e formatar BLUPs
extract_blup = function(model, pattern = "gen:env", init_row = 1, end_row = nrow(summary(model, coef = TRUE)$coef.random) , top_n = 10) {
blup_df = summary(model, coef = TRUE)$coef.random %>%
# manter apenas linhas que contenham o padrão desejado
{ .[grep(pattern, rownames(.)), ] } %>%
# excluir linhas com "iblock"
{ .[!grepl("iblock", rownames(.)), ] } %>%
as.data.frame() %>%
slice(init_row:end_row) %>%
mutate(gen = rownames(.)) %>%
select(gen, solution, std.error) %>%
arrange(desc(solution))
# Criar tabela gt
tab = blup_df %>%
slice(1:top_n) %>%
gt(rowname_col = "gen") %>%
tab_header(
title = paste("Highest", top_n, "BLUPs ")
) %>%
fmt_number(
columns = c(solution, std.error),
decimals = 2
) %>%
tab_options(
table.width = pct(80)
)
return(list(blup = blup_df, table = tab))
}
