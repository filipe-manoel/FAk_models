# Função robusta para transformar matriz (diag = variâncias, off-diag = correlações 
# possivelmente apenas numa das triangulares) em matriz de correlações e covariâncias.
make_cov_mat = function(mat, tol = 1e-8) {
  if (!is.matrix(mat)) stop("mat must be a matrix")
  n = nrow(mat)
  if (ncol(mat) != n) stop("mat must be square")
  
  vars = diag(mat)
  if (any(is.na(vars))) stop("Some diagonal variances are NA")
  
  # inicializa matriz de correlações
  cors = matrix(NA_real_, n, n)
  diag(cors) = 1
  
  for (i in 1:n) {
    for (j in 1:n) {
      if (i == j) next
      v_ij = mat[i, j]
      v_ji = mat[j, i]
      
      if (!is.na(v_ij) && !is.na(v_ji)) {
        # se ambos presentes, checar se são semelhantes; se não, reporta/médio
        if (abs(v_ij - v_ji) > tol) {
          warning(sprintf("correlation mismatch for (%d,%d): %.6f vs %.6f -> using mean",
                          i, j, v_ij, v_ji))
        }
        cors[i, j] = mean(c(v_ij, v_ji), na.rm = TRUE)
      } else if (!is.na(v_ij)) {
        cors[i, j] = v_ij
      } else if (!is.na(v_ji)) {
        cors[i, j] = v_ji
      } else {
        stop(sprintf("No correlation provided for pair (%d,%d)", i, j))
      }
    }
  }
  
  # agora converte para covariância: Cov = D^(1/2) %*% Corr %*% D^(1/2)
  D_sqrt = diag(sqrt(vars))
  cov_mat = D_sqrt %*% cors %*% D_sqrt
  colnames(cov_mat) = rownames(cov_mat) = colnames(mat)
  colnames(cors) = rownames(cors) = colnames(mat)
  
  list(cor = cors, cov = cov_mat)
}

